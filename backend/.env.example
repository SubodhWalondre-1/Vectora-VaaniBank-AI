# VaaniBank AI — Environment Variables Template
# PSBs Hackathon 2026 | Team Vectora

# ── Database (PostgreSQL) ──────────────────────────────────
# Local: postgresql://vaanibank:vaanibank12345@localhost:5432/vaanibank_db
# Cloud (Neon.tech): postgresql+asyncpg://[user]:[password]@[neon-hostname]/neondb?sslmode=require
DATABASE_URL=postgresql+asyncpg://neondb_owner:your_neon_password@ep-rapid-water-a5xxxxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ── Redis Cache & Task Broker ──────────────────────────────
# Local: redis://localhost:6379/0
# Cloud (Upstash): rediss://default:your_upstash_token@shared-redis-xxxxx.upstash.io:6379
REDIS_URL=rediss://default:your_upstash_token@shared-redis-xxxxx.upstash.io:6379
CELERY_BROKER_URL=rediss://default:your_upstash_token@shared-redis-xxxxx.upstash.io:6379/1

# ── JWT Authentication ─────────────────────────────────────
# Generate a strong 256-bit key for production use
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# ── Sarvam AI (STT Primary + TTS) ──────────────────────────
# Get keys from: https://sarvam.ai/
SARVAM_API_KEY=your-sarvam-api-key-here
SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech
SARVAM_TTS_MODEL=bulbul:v3

# ── Reverie RevUp (STT Fallback 2 — BFSI Domain Specific) ──
# Get keys from: https://revup.reverieinc.com/
REVERIE_APP_ID=your-reverie-app-id-here
REVERIE_API_KEY=your-reverie-api-key-here

# ── Groq (LLM Primary + STT Fallback 1 via Whisper) ────────
# Get keys from: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1000

# ── Google Gemini (LLM Fallback — Circuit Breaker) ─────────
# Get keys from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ── OpenRouter (LLM Fallback 2) ─────────────────────────────
# Get keys from: https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# ── Admin Credentials (Auto-Seeding) ──────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_STAFF_ID=UBI-MUM-042
ADMIN_FULL_NAME=Amit Patel

# ── Local File Storage Directories ─────────────────────────
AUDIO_STORAGE_PATH=./storage/audio
SUMMARY_STORAGE_PATH=./storage/summaries
SIGNATURE_STORAGE_PATH=./storage/signatures

# ── Application Environment Settings ───────────────────────
APP_ENV=development
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
DEMO_MODE=true

# ── Customer Panel Web/Kiosk URL (used in QR codes) ───────
APP_URL=http://localhost:5174

# ── Cloudflare R2 Object Storage (Optional) ───────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_URL=your-r2-public-url-here


